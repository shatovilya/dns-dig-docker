# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

# Autonomous mode (continuous DNS testing on startup)
AUTONOMOUS_MODE=false
AUTONOMOUS_RECORDS=["example.com","google.com"]
AUTONOMOUS_RPS=10
AUTONOMOUS_CONCURRENCY=5
AUTONOMOUS_QUERY_TYPES=["A","AAAA"]
AUTONOMOUS_RESOLVE_MODES=["system","absolute_fqdn"]
AUTONOMOUS_NDOTS_VALUES=[4,5]
AUTONOMOUS_TIMEOUT_SECONDS=2.0
AUTONOMOUS_TEST_ID=autonomous

# Test defaults
DEFAULT_RPS=10
DEFAULT_CONCURRENCY=5
DEFAULT_DURATION_SECONDS=60
DEFAULT_TIMEOUT_SECONDS=2.0
DEFAULT_RECORDS=["example.com","kubernetes.default.svc.cluster.local"]
DEFAULT_QUERY_TYPES=["A","AAAA"]
DEFAULT_RESOLVE_MODES=["system","absolute_fqdn"]
DEFAULT_NDOTS_VALUES=[4,5]

# Limits
MAX_RPS=100
MAX_CONCURRENCY=50
MAX_DURATION_SECONDS=3600
MAX_RECORDS=20

# Heuristics
EVENT_BUFFER_SIZE=1000
DUPLICATE_WINDOW_SECONDS=2.0
CACHE_LATENCY_THRESHOLD_MS=5.0
CACHE_LATENCY_RATIO=0.5

# Metrics
METRICS_ENABLED=true

# Shutdown
SHUTDOWN_TIMEOUT_SECONDS=5.0

# Resolver
RESOLV_CONF_PATH=/etc/resolv.conf

# Diagnosis thresholds (ndots/search analytics)
DIAGNOSIS_FQDN_LATENCY_DELTA_MS=50
DIAGNOSIS_SEARCH_NXDOMAIN_RATIO=0.1
DIAGNOSIS_ERROR_RATE_THRESHOLD=0.05
DIAGNOSIS_AMPLIFICATION_RATIO=2.0

# MTR network diagnostics (TCP path to a target service)
MTR_ENABLED=false
MTR_SERVICE_NAME=
MTR_SERVICE_PORT=443
MTR_COUNT=20
MTR_INTERVAL_SECONDS=300
MTR_TIMEOUT_SECONDS=120
MTR_MAX_HISTORY=10

# --- API Security ---
ENVIRONMENT=production
API_AUTH_ENABLED=false
# API_STATIC_CREDENTIALS_JSON=[{"id":"reader","secret":"CHANGE_ME","role":"read-only"},{"id":"operator","secret":"CHANGE_ME","role":"operator"}]
API_BEARER_TOKENS=
API_KEYS=
API_ADMIN_KEYS=
API_BASIC_AUTH_ENABLED=false
API_BASIC_AUTH_USERNAME=
API_BASIC_AUTH_PASSWORD=

API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_READ_RPM=120
API_RATE_LIMIT_WRITE_RPM=30
API_RATE_LIMIT_EXPENSIVE_RPM=10
API_RATE_LIMIT_BURST=20

API_IP_ALLOWLIST=
API_ADMIN_IP_ALLOWLIST=

API_CORS_ENABLED=false
API_CORS_ALLOW_ORIGINS=
API_CORS_ALLOW_CREDENTIALS=false

TRUST_PROXY_ENABLED=false
TRUST_PROXY_IPS=127.0.0.1/32,10.0.0.0/8
REQUIRE_HTTPS=false
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000

API_MAX_BODY_BYTES=262144
API_MAX_RECORDS_PER_RUN=500
API_MAX_FQDN_LENGTH=253
API_MAX_RESOLVERS_PER_RUN=20
API_ALLOWED_QUERY_TYPES=A,AAAA
API_EXPOSE_ERROR_DETAILS=false

DNS_MAX_CONCURRENT_RUNS=3
DNS_MAX_RUN_DURATION_SECONDS=300
DNS_MAX_ACTIVE_JOBS_PER_TOKEN=2

MTR_AUTH_REQUIRED=true
MTR_MAX_CONCURRENT_RUNS=2
MTR_MAX_TARGETS_PER_RUN=20
MTR_MAX_HOPS=32

PROMETHEUS_AUTH_ENABLED=false
PROMETHEUS_BEARER_TOKEN=
PROMETHEUS_IP_ALLOWLIST=
PROMETHEUS_TRUST_INTERNAL_NETWORKS=true

# Web UI (optional)
DNS_DEBUG_UI_ENABLED=false
DNS_DEBUG_UI_AUTH_ENABLED=true
DNS_DEBUG_UI_READONLY=true
DNS_DEBUG_UI_BASE_PATH=/dns-debug
DNS_DEBUG_UI_REFRESH_SECONDS=5
DNS_DEBUG_UI_IP_ALLOWLIST=

# UI snapshot persistence (historical mode)
SNAPSHOT_ENABLED=true
SNAPSHOT_DIR=data/snapshots
SNAPSHOT_RETENTION_COUNT=20
