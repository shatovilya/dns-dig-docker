# Files excluded from Cursor indexing (secrets, caches, build artifacts).
# Project docs (.ai/, .cursor/rules/, AGENT.md) are intentionally indexed.

# Local secrets and env overrides
.env
.env.*
!.env.example

# Secrets / certs
*.pem
*.key
*.p12
secrets/

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
dmypy.json
.python-version
.cache/
*.prof

# Virtual environments
.venv/
venv/
ENV/
env/

# Build artifacts
dist/
build/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
wheels/
uv.lock

# Coverage reports
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Docker local overrides
docker-compose.override.yml
docker-compose.*.local.yml

# Git internals
.git/

# IDE / OS noise
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# Logs and temp files
*.log
logs/
tmp/
temp/
